{
  "name": "frontend.embed",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --mode dev --host 127.0.0.1 --port 3000 --strictPort",
    "dev:stg": "vite --mode stg --host 127.0.0.1 --port 3000 --strictPort",
    "dev:pro": "vite --mode pro --host 127.0.0.1 --port 3000 --strictPort",
    "build": "vue-tsc -b && vite build --mode dev",
    "build:stg": "vue-tsc -b && vite build --mode stg",
    "build:pro": "vue-tsc -b && vite build --mode pro",
    "preview": "vite preview --mode dev",
    "preview:stg": "vite preview --mode stg",
    "preview:pro": "vite preview --mode pro"
  },
  "dependencies": {
    "@infound/desktop-base": "^1.0.0",
    "@infound/desktop-electron": "^1.0.0",
    "axios": "^1.13.6",
    "naive-ui": "^2.43.2",
    "pinia": "^3.0.4",
    "radash": "^12.1.1",
    "vue": "^3.5.25",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@iconify-json/circle-flags": "^1.2.10",
    "@iconify-json/hugeicons": "^1.2.23",
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vitejs/plugin-vue-jsx": "^5.1.4",
    "@vue/tsconfig": "^0.8.1",
    "eslint": "^10.0.1",
    "eslint-plugin-vue": "^10.8.0",
    "prettier": "^3.8.1",
    "sass": "^1.97.3",
    "typescript": "~5.9.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-icons": "^23.0.1",
    "unplugin-vue-components": "^31.0.0",
    "vite": "^7.3.2",
    "vue-tsc": "^3.1.5"
  }
}
