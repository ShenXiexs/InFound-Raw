{
  "name": "xunda",
  "productName": "寻达",
  "version": "0.0.37",
  "description": "TK达人营销增长引擎",
  "main": "./out/main/index.cjs",
  "author": "xunda.club",
  "homepage": "https://www.xunda.club",
  "type": "module",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "vue-tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "pnpm -r --filter=@infound/* build && electron-vite dev --mode dev",
    "dev:mac": "pnpm -r --filter=@infound/* build && electron-vite dev --mode dev",
    "dev:win": "chcp 65001 && pnpm -r --filter=@infound/* build && electron-vite dev --mode dev",
    "prepare:playwright": "electron-builder install-app-deps && cross-env PLAYWRIGHT_BROWSERS_PATH=0 playwright install chromium"
  },
  "dependencies": {
    "@infound/desktop-base": "workspace:*",
    "@infound/desktop-electron": "workspace:*",
    "@infound/desktop-rpa": "workspace:*",
    "@stomp/stompjs": "^7.3.0",
    "electron-store": "8.2.0",
    "electron-updater": "^6.8.3",
    "keytar": "^7.9.0",
    "node-machine-id": "^1.1.12",
    "pino": "^10.3.1",
    "pino-roll": "^4.0.0",
    "playwright-core": "1.58.2",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "radash": "^12.1.1",
    "reflect-metadata": "^0.2.2",
    "vfonts": "^0.0.3",
    "ws": "^8.19.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron-toolkit/utils": "^4.0.0",
    "@iconify-json/circle-flags": "^1.2.10",
    "@iconify-json/hugeicons": "^1.2.23",
    "@intlify/unplugin-vue-i18n": "^11.0.7",
    "@types/node": "^24.10.13",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-vue": "^6.0.4",
    "cross-env": "^10.1.0",
    "electron": "40.8.4",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^10.0.1",
    "eslint-plugin-vue": "^10.8.0",
    "naive-ui": "^2.43.2",
    "pinia": "^3.0.4",
    "playwright": "1.58.2",
    "prettier": "^3.8.1",
    "sass": "^1.97.3",
    "typescript": "^5.9.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-icons": "^23.0.1",
    "unplugin-vue-components": "^31.0.0",
    "vite": "^7.3.1",
    "vue": "^3.5.28",
    "vue-eslint-parser": "^10.4.0",
    "vue-i18n": "^11.2.8",
    "vue-router": "^5.0.3",
    "vue-tsc": "^3.2.5"
  }
}
