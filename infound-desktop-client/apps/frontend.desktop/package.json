{
  "name": "xunda",
  "version": "1.0.1",
  "description": "TK达人营销增长引擎",
  "main": "./out/main/index.js",
  "author": "xunda.club",
  "homepage": "https://www.xunda.club",
  "type": "module",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "vue-tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev --mode dev",
    "dev:win": "chcp 65001 && electron-vite dev --mode dev",
    "build": "npm run typecheck && electron-vite build",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:stg:win": "npm run build:stg && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "postinstall": "electron-builder install-app-deps && cross-env PLAYWRIGHT_BROWSERS_PATH=0 playwright install chromium",
    "pack:dir": "electron-builder --dir",
    "pack": "electron-builder",
    "dist": "pnpm run build && electron-builder"
  },
  "build": {
    "appId": "com.infound.desktop",
    "productName": "Infound Desktop",
    "artifactName": "${productName}-win32_x64-${version}-signed.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "node_modules/**/*",
      "!**/*.map"
    ],
    "extraResources": [
      {
        "from": "resources/chrome-headless-shell-win64.zip",
        "to": "browser/chrome-headless-shell.zip"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "license": "build/license.txt",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeader": "build/logo.bmp",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Infound Desktop"
    }
  },
  "dependencies": {
    "@infound/desktop-shared": "workspace:*",
    "@stomp/stompjs": "^7.3.0",
    "electron-log": "^5.4.3",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "keytar": "^7.9.0",
    "node-machine-id": "^1.1.12",
    "playwright-core": "1.58.2",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "radash": "^12.1.1",
    "reflect-metadata": "^0.2.2",
    "stompjs": "^2.3.3",
    "vfonts": "^0.0.3",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron-toolkit/utils": "^4.0.0",
    "@iconify-json/circle-flags": "^1.2.10",
    "@iconify-json/hugeicons": "^1.2.23",
    "@intlify/unplugin-vue-i18n": "^11.0.7",
    "@types/node": "^24.10.13",
    "@types/stompjs": "^2.3.10",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-vue": "^6.0.4",
    "cross-env": "^10.1.0",
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^10.0.1",
    "eslint-plugin-vue": "^10.8.0",
    "naive-ui": "^2.43.2",
    "pinia": "^3.0.4",
    "playwright": "1.58.2",
    "prettier": "^3.8.1",
    "sass": "^1.97.3",
    "typescript": "^5.9.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-icons": "^23.0.1",
    "unplugin-vue-components": "^31.0.0",
    "vite": "^7.3.1",
    "vue": "^3.5.28",
    "vue-eslint-parser": "^10.4.0",
    "vue-i18n": "^11.2.8",
    "vue-router": "^5.0.3",
    "vue-tsc": "^3.2.5"
  }
}
