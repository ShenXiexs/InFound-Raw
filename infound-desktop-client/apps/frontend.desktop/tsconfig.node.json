{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "include": ["electron.vite.config.*", "env.d.ts", "src/common/**/*", "src/main/**/*", "src/preload/**/*"],
  "compilerOptions": {
    "baseUrl": ".",
    "composite": true,
    "types": ["electron-vite/node"],
    "paths": {
      "@common/*": ["src/common/*"],
      "@desktop-rpa": ["../../packages/frontend.desktop.rpa/src/index.ts"],
      "@desktop-rpa/*": ["../../packages/frontend.desktop.rpa/src/*"],
      "@infound/desktop-base": ["../../packages/frontend.desktop.base/src/index.ts"],
      "@infound/desktop-electron": ["../../packages/frontend.desktop.electron/src/index.ts"],
      "pino-roll": ["../../packages/frontend.desktop.electron/src/types/pino-roll.d.ts"]
    },
    "module": "ESNext",
    "target": "ESNext",
    "moduleResolution": "bundler",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "strict": true
  }
}
